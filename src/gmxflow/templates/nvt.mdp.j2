define          = -DPOSRES
integrator      = md
dt              = {{ config.simulation.dt_ps }}
nsteps          = {{ config.simulation.nvt_steps }}
nstxout         = 500
nstvout         = 500
nstenergy       = 100
cutoff-scheme   = Verlet
nstlist         = 20
coulombtype     = PME
rcoulomb        = 1.2
vdwtype         = Cut-off
rvdw            = 1.2
constraints     = h-bonds
constraint-algorithm = LINCS
continuation    = no
gen-vel         = yes
gen-temp        = {{ config.simulation.temperature_k }}
gen-seed        = 42
tcoupl          = V-rescale
tc-grps         = Protein Non-Protein
tau-t           = 0.1 0.1
ref-t           = {{ config.simulation.temperature_k }} {{ config.simulation.temperature_k }}
pcoupl          = no
pbc             = xyz
