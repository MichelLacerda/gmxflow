integrator      = md
dt              = {{ config.simulation.dt_ps }}
nsteps          = {{ config.simulation.production_steps }}
nstxout         = 0
nstvout         = 0
nstenergy       = {{ 1 if config.simulation.profile == "smoke" else 5000 }}
nstlog          = {{ 1 if config.simulation.profile == "smoke" else 5000 }}
nstxout-compressed = {{ 1 if config.simulation.profile == "smoke" else 5000 }}
cutoff-scheme   = Verlet
nstlist         = 20
coulombtype     = PME
rcoulomb        = 1.2
vdwtype         = Cut-off
rvdw            = 1.2
constraints     = h-bonds
constraint-algorithm = LINCS
continuation    = yes
tcoupl          = V-rescale
tc-grps         = Protein Non-Protein
tau-t           = 0.1 0.1
ref-t           = {{ config.simulation.temperature_k }} {{ config.simulation.temperature_k }}
pcoupl          = Parrinello-Rahman
pcoupltype      = isotropic
tau-p           = 2.0
ref-p           = {{ config.simulation.pressure_bar }}
compressibility = 4.5e-5
pbc             = xyz
comm-mode       = Linear
nstcomm         = 100
