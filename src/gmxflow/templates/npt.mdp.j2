define          = -DPOSRES
integrator      = md
dt              = {{ config.simulation.dt_ps }}
nsteps          = {{ config.simulation.npt_steps }}
nstxout         = 500
nstvout         = 500
nstenergy       = 100
cutoff-scheme   = Verlet
nstlist         = 20
coulombtype     = PME
rcoulomb        = 1.2
vdwtype         = Cut-off
rvdw            = 1.2
constraints     = h-bonds
constraint-algorithm = LINCS
continuation    = yes
tcoupl          = V-rescale
tc-grps         = Protein Non-Protein
tau-t           = 0.1 0.1
ref-t           = {{ config.simulation.temperature_k }} {{ config.simulation.temperature_k }}
pcoupl          = C-rescale
pcoupltype      = isotropic
tau-p           = 2.0
ref-p           = {{ config.simulation.pressure_bar }}
compressibility = 4.5e-5
refcoord_scaling = com
pbc             = xyz
